<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Hub Dashboard - Gemini Style</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        geminiBg: '#131314',
                        geminiCard: 'rgba(255, 255, 255, 0.05)',
                        geminiGlass: 'rgba(255, 255, 255, 0.1)',
                    }
                }
            }
        }
    </script>
    <style>
        body { 
            background: linear-gradient(135deg, #131314 0%, #1a1a1a 100%);
            backdrop-filter: blur(10px);
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .sidebar-link {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .sidebar-link:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: translateX(8px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }
        .card-hover {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .card-hover:hover {
            transform: translateY(-12px) scale(1.02);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
            border-color: rgba(255, 255, 255, 0.2);
        }
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
            }
            .sidebar.open {
                transform: translateX(0);
            }
        }
    </style>
</head>
<body class="min-h-screen text-white font-sans antialiased overflow-x-hidden">
    <!-- Mobile Menu Overlay -->
    <div id="mobileOverlay" class="fixed inset-0 bg-black bg-opacity-50 z-40 lg:hidden hidden"></div>

    <!-- Fixed Sidebar -->
    <aside id="sidebar" class="sidebar fixed left-0 top-0 h-full w-72 lg:w-80 bg-geminiBg/80 backdrop-blur-xl border-r border-white/10 z-50 shadow-2xl">
        <!-- Logo & New Feature Button -->
        <div class="p-6 border-b border-white/10">
            <div class="flex items-center space-x-3 mb-6">
                <i class="fas fa-robot text-2xl text-blue-400"></i>
                <h1 class="text-xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
                    AI Hub
                </h1>
            </div>
            <button id="newFeatureBtn" class="w-full flex items-center space-x-3 p-4 rounded-2xl glass-card hover:bg-white/20 transition-all duration-300 group">
                <i class="fas fa-plus text-xl group-hover:rotate-90 transition-transform"></i>
                <span class="font-semibold">New Chat</span>
            </button>
        </div>

        <!-- Navigation Links -->
        <nav class="p-4 space-y-1">
            <a href="#" data-page="home" class="sidebar-link flex items-center space-x-3 p-4 rounded-xl text-lg group">
                <i class="fas fa-home text-blue-400"></i>
                <span>Home</span>
            </a>
            <a href="#" data-page="allrounder" class="sidebar-link flex items-center space-x-3 p-4 rounded-xl text-lg group">
                <i class="fas fa-brain text-green-400"></i>
                <span>All-Rounder AI</span>
            </a>
            <a href="#" data-page="design" class="sidebar-link flex items-center space-x-3 p-4 rounded-xl text-lg group">
                <i class="fas fa-palette text-pink-400"></i>
                <span>Design Studio</span>
            </a>
            <a href="#" data-page="productivity" class="sidebar-link flex items-center space-x-3 p-4 rounded-xl text-lg group">
                <i class="fas fa-rocket text-orange-400"></i>
                <span>Productivity Hub</span>
            </a>
            <a href="#" data-page="settings" class="sidebar-link flex items-center space-x-3 p-4 rounded-xl text-lg group">
                <i class="fas fa-cog text-gray-400"></i>
                <span>Settings</span>
            </a>
        </nav>

        <!-- Mobile Menu Toggle -->
        <button id="mobileToggle" class="lg:hidden absolute top-6 right-6 p-2 rounded-lg hover:bg-white/10">
            <i class="fas fa-bars text-xl"></i>
        </button>
    </aside>

    <!-- Main Content Area -->
    <main class="ml-0 lg:ml-80 min-h-screen p-8 transition-all duration-300">
        <!-- Pages Container -->
        <div id="pagesContainer">
            <!-- Home Page -->
            <section id="home" class="page active">
                <div class="max-w-6xl mx-auto">
                    <div class="text-center mb-16">
                        <h1 class="text-5xl md:text-6xl font-bold bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent mb-6">
                            Welcome to AI Hub
                        </h1>
                        <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
                            Discover the power of AI with our curated collection of top tools. 
                            From creative design to productivity boosters, everything you need in one place.
                        </p>
                    </div>

                    <!-- Top AI Tools Cards -->
                    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                        <div class="card-hover glass-card p-8 rounded-3xl cursor-pointer group">
                            <div class="w-20 h-20 bg-gradient-to-r from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                                <i class="fas fa-brain text-2xl"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-3 text-white">All-Rounder AI</h3>
                            <p class="text-gray-400 mb-6 leading-relaxed">ChatGPT, Claude, Perplexity</p>
                            <div class="flex items-center space-x-2">
                                <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
                                <span class="text-sm text-green-400 font-medium">Live</span>
                            </div>
                        </div>

                        <div class="card-hover glass-card p-8 rounded-3xl cursor-pointer group">
                            <div class="w-20 h-20 bg-gradient-to-r from-pink-500 to-purple-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                                <i class="fas fa-palette text-2xl"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-3 text-white">Design Studio</h3>
                            <p class="text-gray-400 mb-6 leading-relaxed">Midjourney, Canva, Lensa</p>
                            <div class="flex items-center space-x-2">
                                <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
                                <span class="text-sm text-green-400 font-medium">Live</span>
                            </div>
                        </div>

                        <div class="card-hover glass-card p-8 rounded-3xl cursor-pointer group">
                            <div class="w-20 h-20 bg-gradient-to-r from-orange-500 to-yellow-500 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                                <i class="fas fa-rocket text-2xl"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-3 text-white">Productivity</h3>
                            <p class="text-gray-400 mb-6 leading-relaxed">Grammarly, Otter.ai, Character.ai</p>
                            <div class="flex items-center space-x-2">
                                <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
                                <span class="text-sm text-green-400 font-medium">Live</span>
                            </div>
                        </div>

                        <div class="card-hover glass-card p-8 rounded-3xl cursor-pointer group">
                            <div class="w-20 h-20 bg-gradient-to-r from-green-500 to-emerald-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
                                <i class="fas fa-magic text-2xl"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-3 text-white">New Chat</h3>
                            <p class="text-gray-400 mb-6 leading-relaxed">Start fresh conversation</p>
                            <div class="flex items-center space-x-2">
                                <div class="w-3 h-3 bg-blue-400 rounded-full animate-pulse"></div>
                                <span class="text-sm text-blue-400 font-medium">Ready</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- All-Rounder AI Page -->
            <section id="allrounder" class="page hidden">
                <div class="max-w-6xl mx-auto">
                    <h2 class="text-4xl font-bold mb-12 bg-gradient-to-r from-green-400 to-blue-400 bg-clip-text text-transparent">
                        <i class="fas fa-brain mr-4"></i>All-Rounder AI
                    </h2>
                    <div class="grid md:grid-cols-3 gap-8">
                        <div class="glass-card p-10 rounded-3xl card-hover">
                            <div class="w-24 h-24 bg-gradient-to-br from-blue-500 to-blue-700 rounded-3xl flex items-center justify-center mb-8 mx-auto">
                                <i class="fas fa-comments text-3xl text-white"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-4 text-center">ChatGPT</h3>
                            <p class="text-gray-300 mb-8 text-center leading-relaxed">OpenAI's revolutionary conversational AI. Perfect for coding, writing, brainstorming, and complex problem-solving.</p>
                            <a href="https://chat.openai.com" target="_blank" class="w-full bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white py-4 px-8 rounded-2xl font-semibold flex items-center justify-center space-x-2 transition-all duration-300">
                                <i class="fas fa-external-link-alt"></i>
                                <span>Try ChatGPT</span>
                            </a>
                        </div>

                        <div class="glass-card p-10 rounded-3xl card-hover">
                            <div class="w-24 h-24 bg-gradient-to-br from-purple-500 to-purple-700 rounded-3xl flex items-center justify-center mb-8 mx-auto">
                                <i class="fas fa-magic text-3xl text-white"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-4 text-center">Claude</h3>
                            <p class="text-gray-300 mb-8 text-center leading-relaxed">Anthropic's safe and helpful AI assistant. Excels at reasoning, coding, and handling long context conversations.</p>
                            <a href="https://claude.ai" target="_blank" class="w-full bg-gradient-to-r from-purple-500 to-purple-600 hover:from-purple-600 hover:to-purple-700 text-white py-4 px-8 rounded-2xl font-semibold flex items-center justify-center space-x-2 transition-all duration-300">
                                <i class="fas fa-external-link-alt"></i>
                                <span>Try Claude</span>
                            </a>
                        </div>

                        <div class="glass-card p-10 rounded-3xl card-hover">
                            <div class="w-24 h-24 bg-gradient-to-br from-orange-500 to-red-600 rounded-3xl flex items-center justify-center mb-8 mx-auto">
                                <i class="fas fa-search text-3xl text-white"></i>
                            </div>
                            <h3 class="text-2xl font-bold mb-4 text-center">Perplexity</h3>
                            <p class="text-gray-300 mb-8 text-center leading-relaxed">AI-powered answer engine with real-time web search. Perfect for research and getting accurate information fast.</p>
                            <a href="https://www.perplexity.ai" target="_blank" class="w-full bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white py-4 px-8 rounded-2xl font-semibold flex items-center justify-center space-x-2 transition-all duration-300">
                                <i class="fas fa-external-link-alt"></i>
                                <span>Try Perplexity</span>
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Design Studio Page -->
            <section id="design" class="page hidden">
                <div class="max-w-6xl mx-auto">
                    <h2 class="text-4xl font-bold mb-12 bg-gradient-to-r from-pink-400 to-purple-500 bg-clip-text text-transparent">
                        <i class="fas fa-palette mr-4"></i>Design Studio
                    </h2>
                    <div class="space-y-8">
                        <div class="glass-card p-10 rounded-3xl card-hover">
                            <div class="flex items-start space-x-6">
                                <div class="w-28 h-28 bg-gradient-to-br from-pink-500 to-red-600 rounded-3xl flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-image text-3xl text-white"></i>
                                </div>
                                <div class="flex-1">
                                    <h3 class="text-3xl font-bold mb-4">Midjourney</h3>
                                    <p class="text-gray-300 mb-6 leading-relaxed">Generate stunning AI art and images from text prompts. Discord-powered platform loved by artists worldwide.</p>
                                    <a href="https://www.midjourney.com" target="_blank" class="inline-flex items-center space-x-2 bg-gradient-to-r from-pink-500 to-purple-500 hover:from-pink-600 hover:to-purple-600 text-white py-3 px-6 rounded-2xl font-semibold transition-all duration-300">
                                        <i class="fas fa-external-link-alt"></i>
                                        <span>Visit Midjourney</span>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card p-10 rounded-3xl card-hover">
                            <div class="flex items-start space-x-6">
                                <div class="w-28 h-28 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-3xl flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-layer-group text-3xl text-white"></i>
                                </div>
                                <div class="flex-1">
                                    <h3 class="text-3xl font-bold mb-4">Canva</h3>
                                    <p class="text-gray-300 mb-6 leading-relaxed">Magic Studio brings AI-powered design tools to everyone. Create professional graphics, presentations, and videos effortlessly.</p>
                                    <a href="https://www.canva.com" target="_blank" class="inline-flex items-center space-x-2 bg-gradient-to-r from-blue-500 to-cyan-500 hover:from-blue-600 hover:to-cyan-600 text-white py-3 px-6 rounded-2xl font-semibold transition-all duration-300">
                                        <i class="fas fa-external-link-alt"></i>
                                        <span>Visit Canva</span>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="glass-card p-10 rounded-3xl card-hover">
                            <div class="flex items-start space-x-6">
                                <div class="w-28 h-28 bg-gradient-to-br from-purple-500 to-indigo-600 rounded-3xl flex items-center justify-center flex-shrink-0">
                                    <i class="fas fa-selfie text-3xl text-white"></i>
                                </div>
                                <div class="flex-1">
                                    <h3 class="text-3xl font-bold mb-4">Lensa AI</h3>
                                    <p class="text-gray-300 mb-6 leading-relaxed">Transform selfies into magical avatars with AI. Perfect for creating unique profile pictures and artistic portraits.</p>
                                    <a href="https://prisma-ai.com/lensa" target="_blank" class="inline-flex items-center space-x-2 bg-gradient-to-r from-purple-500 to-indigo-500 hover:from-purple-600 hover:to-indigo-600 text-white py-3 px-6 rounded-2xl font-semibold transition-all duration-300">
                                        <i class="fas fa-external-link-alt"></i>
                                        <span>Try Lensa</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Productivity Hub Page -->
            <section id="productivity" class="page hidden">
                <div class="max-w-6xl mx-auto">
                    <h2 class="text-4xl font-bold mb-12 bg-gradient-to-r from-orange-400 to-yellow-400 bg-clip-text text-transparent">
                        <i class="fas fa-rocket mr-4"></i>Productivity Hub
                    </h2>
                    <div class="grid md:grid-cols-3 gap-8">
                        <div class="glass-card p-10 rounded-3xl card-hover">
                           
