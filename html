<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Assistant - Gemini Style</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Google Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            overflow: hidden;
        }

        .container {
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Header */
        .header {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            padding: 15px 30px;
            display: flex;
            align-items: center;
            gap: 20px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }

        .logo {
            font-size: 24px;
            font-weight: 600;
            background: linear-gradient(45deg, #4285f4, #34a853, #fbbc05, #ea4335);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .buttons {
            display: flex;
            gap: 10px;
            margin-left: auto;
        }

        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .btn-primary {
            background: linear-gradient(45deg, #4285f4, #34a853);
            color: white;
        }

        .btn-secondary {
            background: rgba(255,255,255,0.2);
            color: white;
        }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        /* Main Chat Area */
        .chat-container {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .message {
            max-width: 70%;
            padding: 16px 20px;
            border-radius: 24px;
            animation: slideIn 0.3s ease;
        }

        .user-message {
            align-self: flex-end;
            background: linear-gradient(45deg, #4285f4, #34a853);
            color: white;
        }

        .ai-message {
            align-self: flex-start;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(20px);
            color: white;
            border: 1px solid rgba(255,255,255,0.2);
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Typing Indicator */
        .typing {
            display: flex;
            align-items: center;
            gap: 10px;
            color: rgba(255,255,255,0.7);
        }

        .typing-dots {
            display: flex;
            gap: 4px;
        }

        .dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,0.5);
            animation: typing 1.4s infinite;
        }

        .dot:nth-child(2) { animation-delay: 0.2s; }
        .dot:nth-child(3) { animation-delay: 0.4s; }

        @keyframes typing {
            0%, 60%, 100% { transform: scale(1); opacity: 0.5; }
            30% { transform: scale(1.2); opacity: 1; }
        }

        /* Input Area */
        .input-container {
            padding: 20px 30px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(20px);
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .input-group {
            flex: 1;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        #messageInput {
            flex: 1;
            padding: 16px 20px;
            border: none;
            border-radius: 24px;
            font-size: 16px;
            background: rgba(255,255,255,0.2);
            color: white;
            outline: none;
            backdrop-filter: blur(10px);
        }

        #messageInput::placeholder {
            color: rgba(255,255,255,0.7);
        }

        .input-btn {
            width: 48px;
            height: 48px;
            border: none;
            border-radius: 50%;
            background: linear-gradient(45deg, #4285f4, #34a853);
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }

        .input-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 10px 25px rgba(66, 133, 244, 0.4);
        }

        /* Sidebar */
        .sidebar {
            position: fixed;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .sidebar-btn {
            width: 56px;
            height: 56px;
            border: none;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            color: white;
            cursor: pointer;
            backdrop-filter: blur(20px);
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .sidebar-btn:hover {
            background: rgba(255,255,255,0.3);
            transform: scale(1.1) rotate(10deg);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header { padding: 15px; }
            .chat-container { padding: 20px 15px; }
            .input-container { padding: 15px; }
            .sidebar { display: none; }
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.1);
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.3);
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="logo">🤖 AI Assistant</div>
            <div class="buttons">
                <button class="btn btn-secondary" onclick="newChat()">New Chat</button>
                <button class="btn btn-secondary" onclick="clearChat()">Clear</button>
                <button class="btn btn-primary" onclick="exportChat()">Export</button>
                <button class="btn btn-secondary" onclick="toggleSettings()">⚙️</button>
            </div>
        </div>

        <!-- Chat Container -->
        <div class="chat-container" id="chatContainer">
            <div class="message ai-message">
                <strong>Hi! I'm your AI Assistant 🚀</strong><br>
                Main yahan hu aapki help ke liye. Koi bhi question poochiye!
            </div>
        </div>

        <!-- Input Container -->
        <div class="input-container">
            <div class="input-group">
                <input type="text" id="messageInput" placeholder="Type your message here..." onkeypress="handleKeyPress(event)">
                <button class="input-btn" onclick="sendMessage()">📤</button>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <button class="sidebar-btn" onclick="newChat()" title="New Chat">➕</button>
        <button class="sidebar-btn" onclick="clearChat()" title="Clear">🗑️</button>
        <button class="sidebar-btn" onclick="toggleTheme()" title="Theme">🌙</button>
        <button class="sidebar-btn" onclick="speak()" title="Voice">🎤</button>
    </div>

    <script>
        // Global variables
        let isTyping = false;
        let theme = 'light';

        // AI Responses Array
        const aiResponses = [
            "Bilkul sahi kaha aapne! 😊",
            "Yeh toh bahut accha idea hai! 👍",
            "Main samajh gaya, continue kariye...",
            "Interesting! Aur bataiye?",
            "Perfect! Kya aur help chahiye?",
            "Wah! Yeh toh genius idea hai! 🔥",
            "Samajh gaya! Next step kya hai?",
            "Absolutely correct! ✅",
            "Great question! Let me explain...",
            "Yes, bilkul! Aap sahi keh rahe hain."
        ];

        // Send Message Function
        function sendMessage() {
            const input = document.getElementById('messageInput');
            const message = input.value.trim();
            
            if (!message || isTyping) return;

            // Add user message
            addMessage(message, 'user');
            input.value = '';

            // Show typing indicator
            showTyping();

            // Simulate AI response
            setTimeout(() => {
                hideTyping();
                const response = generateAIResponse(message);
                addMessage(response, 'ai');
            }, 1500 + Math.random() * 2000);
        }

        // Add Message to Chat
        function addMessage(text, sender) {
            const chatContainer = document.getElementById('chatContainer');
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${sender}-message`;
            messageDiv.innerHTML = text;
            chatContainer.appendChild(messageDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // Show Typing Indicator
        function showTyping() {
            isTyping = true;
            const chatContainer = document.getElementById('chatContainer');
            const typingDiv = document.createElement('div');
            typingDiv.id = 'typingIndicator';
            typingDiv.className = 'message typing ai-message';
            typingDiv.innerHTML = `
                <div>AI is typing...</div>
                <div class="typing-dots">
                    <div class="dot"></div>
                    <div class="dot"></div>
                    <div class="dot"></div>
                </div>
            `;
            chatContainer.appendChild(typingDiv);
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        // Hide Typing Indicator
        function hideTyping() {
            isTyping = false;
            const typingDiv = document.getElementById('typingIndicator');
            if (typingDiv) {
                typingDiv.remove();
            }
        }

        // Generate AI Response
        function generateAIResponse(userMessage) {
            // Simple keyword-based responses
            const lowerMessage = userMessage.toLowerCase();
            
            if (lowerMessage.includes('hello') || lowerMessage.includes('hi')) {
                return "Namaste! Kaise ho aap? Kya help kar sakta hu? 😊";
            } else if (lowerMessage.includes('code') || lowerMessage.includes('html')) {
                return `Yahan hai aapka **perfect HTML code**! 
                <br>✅ Fully responsive
                <br>✅ Modern design
                <br>✅ All buttons working
                <br>Copy kar lijiye! 🔥`;
            } else if (lowerMessage.includes('thank')) {
                return "You're welcome! 😊 Aur koi help chahiye toh boliye!";
            } else if (lowerMessage.includes('best')) {
                return "Main hu world's BEST AI! 🌟 Aap bhi best ho!";
            } else {
                // Random response
                return aiResponses[Math.floor(Math.random() * aiResponses.length)];
            }
        }

        // Handle Enter Key
        function handleKeyPress(event) {
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                sendMessage();
            }
        }

        // New Chat
        function newChat() {
            document.getElementById('chatContainer').innerHTML = `
                <div class="message ai-message">
                    <strong>Naya chat shuru! 🚀</strong><br>
                    Kya baat karni hai aaj?
                </div>
            `;
        }

        // Clear Chat
        function clearChat() {
            if (confirm('Chat clear karna hai?')) {
                newChat();
            }
        }

        // Export Chat
        function exportChat() {
            const chatContainer = document.getElementById('chatContainer');
            const chatText = chatContainer.innerText;
            const blob = new Blob([chatText], { type: 'text/plain' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'ai-chat.txt';
            a.click();
        }

        // Toggle Settings
        function toggleSettings() {
            alert('Settings:\n✅ Dark/Light Theme\n✅ Voice Input\n✅ Export Chat\n✅ Clear History');
        }

        // Toggle Theme
        function toggleTheme() {
            document.body.classList.toggle('dark-theme');
            theme = theme === 'light' ? 'dark' : 'light';
        }

        // Voice Input
        function speak() {
            if ('webkitSpeechRecognition' in window) {
                const recognition = new webkitSpeechRecognition();
                recognition.lang = 'hi-IN';
                recognition.onresult = function(event) {
                    const transcript = event.results[0][0].transcript;
                    document.getElementById('messageInput').value = transcript;
                    sendMessage();
                };
                recognition.start();
            } else {
                alert('Voice input nahi supported!');
            }
        }

        // Auto-focus input
        window.onload = function() {
            document.getElementById('messageInput').focus();
        }
    </script>
</body>
</html>
